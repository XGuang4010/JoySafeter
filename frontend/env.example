
# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# Docker 容器内部配置（Node.js 服务器监听的内部端口，通常不需要修改）
# 对应的宿主机端口在 deploy/.env 的 FRONTEND_PORT_HOST 中配置
FRONTEND_PORT=3000

# Content Security Policy (CSP) 额外域名配置
# 注意：后端 API 同主机的域名已基于 NEXT_PUBLIC_API_URL 自动生成（含端口通配），无需重复配置
# 此处仅用于添加不同主机 / 第三方域名
# 示例: NEXT_PUBLIC_CSP_CONNECT_SRC_EXTRA="https://api.third-party.com wss://ws.third-party.com"
NEXT_PUBLIC_CSP_CONNECT_SRC_EXTRA=
NEXT_PUBLIC_CSP_FRAME_SRC_EXTRA=
